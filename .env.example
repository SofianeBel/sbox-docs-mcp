# Cache TTL for documentation pages in seconds (default: 4 hours)
SBOX_DOCS_CACHE_TTL=14400

# Maximum number of cached entries (default: 500)
SBOX_DOCS_MAX_CACHE_ENTRIES=500

# HTTP request timeout in milliseconds (default: 10s)
SBOX_DOCS_REQUEST_TIMEOUT=10000

# User-Agent string for outgoing requests
SBOX_DOCS_USER_AGENT=sbox-docs-mcp/0.1.0
